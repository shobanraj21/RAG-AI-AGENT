server {
    listen 80;
    access_log /cholalogs/stageconversationalagent-cholamandalam-com/nginxlogs/$hostname-access.log;

    # Proxy requests to the backend Python application (e.g., Gunicorn)
    location / {
        proxy_pass http://127.0.0.1:5000;  # Gunicorn or your WSGI server's address
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 1200;
        proxy_connect_timeout 1200;
        proxy_send_timeout 1200;
        send_timeout 1200;
    }

    # Deny access to dotfiles and hidden directories (e.g., .git, .env, etc.)
    location ~ /\.. {
        deny all;
    }

    # Handle 404 errors by serving a custom 404 page
    error_page 404 /404.html;
    location = /404.html {
        root /usr/src/app;  # Serve 404 page from /usr/src/app
    }

    # Optionally, handle 500 server errors
    error_page 500 502 503 504 /500.html;
    location = /500.html {
        root /usr/src/app;  # Serve 500 error page from /usr/src/app
    }
}
